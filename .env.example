# Airflow 이미지 (Python 버전 변경 시 태그 수정, 예: apache/airflow:3.1.8-python3.11)
AIRFLOW_IMAGE_NAME=apache/airflow:3.1.8

# 컨테이너 실행 유저/그룹
# Mac/Windows: 50000 그대로
# Linux: `id -u` 결과를 AIRFLOW_UID에 입력
AIRFLOW_UID=50000
AIRFLOW_GID=0

# Fernet key for encrypting connections
# 생성 방법: docker run --rm python:3.12 python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=

# Default admin credentials (change in production)
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow

# Supabase PostgreSQL
SUPABASE_DB_USERNAME=
SUPABASE_DB_PASSWORD=
SUPABASE_DB_HOST=
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
